{
  "name": "@stamcat/localize",
  "version": "1.0.6",
  "description": "A collection of localization tools built on FormatJS & i18n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stamcat/Localize.git"
  },
  "keywords": [
    "formatjs",
    "i18n",
    "internationalization",
    "localization"
  ],
  "author": "Devin Marra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Stamcat/Localize/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "types": "index.d.ts",
  "main": "index.js",
  "homepage": "https://github.com/Stamcat/Localize#readme",
  "scripts": {
    "build:clean": "rm -rf ./lib",
    "build:compile": "tsc -p tsconfig.build.json",
    "build:src": "npm run build:compile && tsx ./buildPackage.ts",
    "build-storybook": "storybook build",
    "lint": "eslint .",
    "lint:commit": "eslint --fix --max-warnings=10",
    "lint:fix": "eslint . --fix",
    "lint:package": "npmPkgJsonLint ./package.json",
    "lint:prod": "eslint . --max-warnings=0",
    "lint:sonar": "eslint . -f json -o lintreport.json",
    "lint:staged": "lint-staged --no-stash",
    "release": "commit-and-tag-version",
    "release:alpha": "npm run release -- --prerelease alpha",
    "release:beta": "npm run release -- --prerelease beta",
    "release:major": "npm run release -- release-as major",
    "release:minor": "npm run release -- release-as minor",
    "release:patch": "npm run release -- release-as patch",
    "storybook": "storybook dev -p 6006",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "flat": "6.0.1",
    "react-intl": "10.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "17.6.6",
    "@commitlint/config-conventional": "17.6.6",
    "@commitlint/prompt": "17.6.6",
    "@commitlint/prompt-cli": "17.6.6",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-links": "10.4.4",
    "@storybook/addon-onboarding": "10.4.4",
    "@storybook/addon-webpack5-compiler-swc": "1.0.2",
    "@storybook/react": "10.4.4",
    "@storybook/react-webpack5": "10.4.4",
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/user-event": "13.5.0",
    "@types/fs-extra": "11.0.4",
    "@types/jest": "27.5.2",
    "@types/node": "16.18.67",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "axios-mock-adapter": "1.22.0",
    "commit-and-tag-version": "11.2.2",
    "dependency-cruiser": "13.1.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-sonarjs": "0.19.0",
    "eslint-plugin-storybook": "0.8.0",
    "husky": "8.0.3",
    "jest": "29.1.2",
    "jest-environment-jsdom": "29.1.2",
    "jest-localstorage-mock": "2.4.26",
    "jest-sonar-reporter": "2.0.0",
    "lint-staged": "13.2.3",
    "npm-package-json-lint": "7.0.0",
    "npm-package-json-lint-config-default": "6.0.0",
    "prettier": "3.2.5",
    "semver": "7.6.0",
    "storybook": "10.4.4",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.1",
    "tsx": "4.7.0",
    "typescript": "6.0.3",
    "zod": "4.3.6"
  },
  "lint-staged": {
    "package-lock.json": "node qualityChecks/check-package-lock.cjs",
    "*.json": "npm run pretty:commit --",
    "src/*.{ts,tsx,js}|*.{ts,tsx}": [
      "npm run lint:commit --fix --silent --"
    ]
  }
}
